POSTGRES_DB=maps
POSTGRES_USER=maps
POSTGRES_PASSWORD=maps
APP_PORT=8080
USE_FILE_STORE=true
EDIT_USERNAME=admin
EDIT_PASSWORD=p1ssw0r

# Base map tile server. For a fully self-hosted setup, replace with your own tile endpoint.
BASE_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
BASE_TILE_ATTRIBUTION=&copy; OpenStreetMap contributors

# StatCan/CMP overlay mode: wms | xyz | arcgis
CMP_MODE=wms

# WMS settings (used when CMP_MODE=wms)
CMP_WMS_URL=
CMP_WMS_LAYERS=
CMP_WMS_FORMAT=image/png
CMP_WMS_VERSION=1.1.1
CMP_WMS_ATTRIBUTION=Source: Statistics Canada

# XYZ settings (used when CMP_MODE=xyz)
CMP_XYZ_URL=
CMP_XYZ_ATTRIBUTION=Source: Statistics Canada

# ArcGIS MapServer settings (used when CMP_MODE=arcgis)
CMP_ARCGIS_URL=
CMP_ARCGIS_ATTRIBUTION=Source: Statistics Canada
CMP_ARCGIS_LAYERS=
# Set to true to route ArcGIS requests through local backend proxy.
CMP_ARCGIS_USE_LOCAL_PROXY=true
# Optional. Upstream cookie/session header for protected CMP services.
CMP_ARCGIS_COOKIE=
